# Neon PostgreSQL (via Netlify integration)
# Pooled connection — used by Prisma at runtime
NETLIFY_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Direct (unpooled) connection — used by Prisma Migrate / db push
NETLIFY_DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=          # generate with: openssl rand -base64 32
NEXTAUTH_URL=https://your-site.netlify.app

# Anthropic (for AI features)
ANTHROPIC_API_KEY=
